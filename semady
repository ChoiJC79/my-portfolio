<title>주문·납품 관리 시스템</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
  * { font-family: 'Malgun Gothic','맑은 고딕',-apple-system,BlinkMacSystemFont,sans-serif; }
  @media print { .no-print{display:none!important;} body{background:#fff!important;} }
  .status-draft{background:#F3F4F6;color:#374151;}
  .status-submitted{background:#EFF6FF;color:#1D4ED8;}
  .status-quoted{background:#FEF3C7;color:#92400E;}
  .status-quote_approved{background:#D1FAE5;color:#065F46;}
  .status-in_progress{background:#FEF9C3;color:#713F12;}
  .status-proof_review{background:#EDE9FE;color:#4C1D95;}
  .status-proof_approved{background:#DCFCE7;color:#14532D;}
  .status-delivering{background:#DBEAFE;color:#1E3A8A;}
  .status-completed{background:#D1FAE5;color:#065F46;}
  .status-cancelled{background:#FEE2E2;color:#7F1D1D;}
  ::-webkit-scrollbar{width:5px;} ::-webkit-scrollbar-track{background:#F1F5F9;} ::-webkit-scrollbar-thumb{background:#CBD5E1;border-radius:3px;}
