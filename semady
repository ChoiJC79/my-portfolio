  .type-label:has(input:checked){border-color:#3B82F6!important;background:#EFF6FF;}
</style>
</head>
<body class="bg-slate-50">
<div id="app"></div>
<script>
// ═══════════════════════════════════════════════════════
//  상수
// ═══════════════════════════════════════════════════════
const STATUS_LABELS = {
  draft:'임시저장', submitted:'접수대기', quoted:'견적발송',
  quote_approved:'견적승인', in_progress:'작업중',
  proof_review:'시안확인', proof_approved:'시안승인',
  delivering:'납품중', completed:'완료', cancelled:'취소'
};
const STATUS_NEXT = {
  submitted:'quoted', quoted:'quote_approved', quote_approved:'in_progress',
  in_progress:'proof_review', proof_review:'proof_approved',
  proof_approved:'delivering', delivering:'completed'
};
const ORDER_TYPES = {
  supplies:'사무용품', toner:'토너·소모품',
  banner:'현수막', advertising:'광고물', repair:'수선·용역'
};
const uid = ()=>Math.random().toString(36).substr(2,9);
const today=()=>new Date().toISOString().split('T')[0];
const fmt=d=>d?d.replace(/-/g,'.'):'—';

// ═══════════════════════════════════════════════════════
//  스토어
// ═══════════════════════════════════════════════════════
const Store = {
  data:{users:[],orders:[],quotes:[],messages:[],
    settings:{bizName:'○○종합유통',bizNo:'000-00-00000',ceo:'대표자명',phone:'043-000-0000',addr:'충청북도 제천시 ○○로 ○○',bank:'국민은행 000-00-0000-00 (예금주: ○○○)'}},
  load(){
    const s=localStorage.getItem('b2g_v3');
