function submitOrder(){
  const title=document.getElementById('nTitle')?.value.trim();
  const typeEl=document.querySelector('input[name="oType"]:checked');
  if(!title||!typeEl){alert('주문 유형과 제목을 입력해 주세요.');return;}
  const type=typeEl.value; const detail={};
  if(type==='banner'){detail.width=document.getElementById('tf_width')?.value;detail.height=document.getElementById('tf_height')?.value;detail.qty=document.getElementById('tf_qty')?.value;detail.material=document.getElementById('tf_material')?.value;detail.text=document.getElementById('tf_text')?.value;}
  else if(type==='advertising'){detail.kind=document.getElementById('tf_kind')?.value;detail.spec=document.getElementById('tf_spec')?.value;detail.qty=document.getElementById('tf_qty')?.value;detail.color=document.getElementById('tf_color')?.value;}
  else if(type==='repair'){detail.workType=document.getElementById('tf_workType')?.value;detail.location=document.getElementById('tf_location')?.value;detail.desc=document.getElementById('tf_desc')?.value;}
  else{detail.items=Array.from(document.querySelectorAll('.sup-row')).map(r=>({name:r.querySelector('.sup-name')?.value,spec:r.querySelector('.sup-spec')?.value,qty:r.querySelector('.sup-qty')?.value,unit:r.querySelector('.sup-unit')?.value})).filter(x=>x.name);}
  const seq=Store.data.orders.length+1;
  const o={id:uid(),orderNo:`ORD-2026-${String(seq).padStart(3,'0')}`,clientId:CU.id,staffId:null,type,status:'submitted',title,detail,desiredDate:document.getElementById('nDate')?.value,deliveryAddr:document.getElementById('nAddr')?.value,note:document.getElementById('nNote')?.value,createdAt:today()};
  Store.data.orders.push(o); Store.save(); go('order-detail',{id:o.id});
}

