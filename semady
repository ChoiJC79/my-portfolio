      {id:'staff1',email:'staff@test.com',pw:'1234',role:'staff',name:'김담당',org:'○○종합유통',dept:'영업팀',phone:'010-0000-0002',addr:'',isActive:true},
      {id:'client1',email:'client@test.com',pw:'1234',role:'client',name:'홍길동',org:'제천시청',dept:'총무과',phone:'043-641-1234',addr:'충청북도 제천시 청전동',isActive:true},
      {id:'client2',email:'client2@test.com',pw:'1234',role:'client',name:'이영희',org:'제천교육지원청',dept:'행정과',phone:'043-640-7000',addr:'충청북도 제천시',isActive:true}
    ];
    this.data.orders=[
      {id:'ord001',orderNo:'ORD-2026-001',clientId:'client1',staffId:'staff1',type:'banner',status:'proof_review',title:'여름 축제 홍보 현수막 제작',detail:{width:400,height:80,qty:5,material:'천',text:'제2회 의림지 여름 축제\n2026.07.15~07.20'},desiredDate:'2026-07-10',deliveryAddr:'충청북도 제천시 청전동 시청 앞',note:'기존 현수막과 동일한 색감 부탁드립니다.',createdAt:'2026-06-20'},
      {id:'ord002',orderNo:'ORD-2026-002',clientId:'client1',staffId:null,type:'supplies',status:'submitted',title:'A4 용지 및 볼펜 구매 건',detail:{items:[{name:'A4 복사용지 80g',spec:'500매/박스',qty:10,unit:'박스'},{name:'볼펜 흑색',spec:'12개입',qty:5,unit:'pack'}]},desiredDate:'2026-07-05',deliveryAddr:'제천시청 총무과',note:'',createdAt:'2026-06-22'},
      {id:'ord003',orderNo:'ORD-2026-003',clientId:'client2',staffId:'staff1',type:'advertising',status:'completed',title:'기관 홍보 브로셔 제작',detail:{kind:'브로셔',spec:'A4 양면',qty:500,color:'4도'},desiredDate:'2026-06-15',deliveryAddr:'제천교육지원청',note:'',createdAt:'2026-06-01'}
    ];
    this.data.quotes=[
      {id:'qt001',quoteNo:'Q-2026-001',orderId:'ord001',items:[{name:'현수막 제작',spec:'400×80cm 천',qty:5,unitPrice:35000,amount:175000}],supplyAmt:175000,vatAmt:17500,totalAmt:192500,validUntil:'2026-07-31',status:'approved',note:'설치비 별도',createdBy:'staff1',createdAt:'2026-06-21'},
      {id:'qt003',quoteNo:'Q-2026-003',orderId:'ord003',items:[{name:'브로셔 인쇄',spec:'A4 양면 4도',qty:500,unitPrice:800,amount:400000},{name:'디자인비',spec:'1식',qty:1,unitPrice:150000,amount:150000}],supplyAmt:550000,vatAmt:55000,totalAmt:605000,validUntil:'2026-06-30',status:'approved',note:'',createdBy:'staff1',createdAt:'2026-06-02'}
    ];
    this.data.messages=[
      {id:'msg001',orderId:'ord001',senderId:'client1',body:'안녕하세요. 현수막 글자 크기를 좀 더 크게 해주실 수 있을까요?',createdAt:'2026-06-21T10:30:00'},
      {id:'msg002',orderId:'ord001',senderId:'staff1',body:'네, 제목 글자를 키운 수정 시안으로 업로드해 드리겠습니다. 잠시 기다려 주세요.',createdAt:'2026-06-21T11:02:00'}
    ];
