function addQtRow(){
  const c=document.getElementById('qItems'); if(!c) return;
  const r=document.createElement('div'); r.className='grid grid-cols-12 gap-2 q-row';
  r.innerHTML=`<input class="qi-n col-span-4 border border-slate-200 rounded-lg px-2 py-2 text-sm focus:outline-none" placeholder="품목명">
    <input class="qi-s col-span-2 border border-slate-200 rounded-lg px-2 py-2 text-sm focus:outline-none" placeholder="규격">
    <input class="qi-q col-span-1 border border-slate-200 rounded-lg px-2 py-2 text-sm text-right focus:outline-none" type="number" value="1" oninput="calcQt()">
    <input class="qi-p col-span-2 border border-slate-200 rounded-lg px-2 py-2 text-sm text-right focus:outline-none" type="number" value="0" oninput="calcQt()">
    <div class="qi-a col-span-2 flex items-center justify-end text-sm font-semibold text-slate-700 pr-1">0</div>
    <button onclick="rmQtRow(this)" class="col-span-1 text-slate-300 hover:text-red-400 text-xl font-bold">×</button>`;
  c.appendChild(r);
}
function rmQtRow(btn){
  const rows=document.querySelectorAll('.q-row'); if(rows.length<=1) return;
  btn.closest('.q-row').remove(); calcQt();
}
function calcQt(){
  let sup=0;
  document.querySelectorAll('.q-row').forEach(r=>{
    const q=parseFloat(r.querySelector('.qi-q')?.value)||0;
    const p=parseFloat(r.querySelector('.qi-p')?.value)||0;
    const a=q*p; const el=r.querySelector('.qi-a');
    if(el) el.textContent=a.toLocaleString(); sup+=a;
  });
  const vat=Math.round(sup*0.1);
  document.getElementById('qS').textContent=sup.toLocaleString()+'원';
  document.getElementById('qV').textContent=vat.toLocaleString()+'원';
  document.getElementById('qT').textContent=(sup+vat).toLocaleString()+'원';
}
function saveQuote(orderId){
  const items=[];
  document.querySelectorAll('.q-row').forEach(r=>{
    const name=r.querySelector('.qi-n')?.value.trim(); if(!name) return;
    const qty=parseFloat(r.querySelector('.qi-q')?.value)||0;
    const unitPrice=parseFloat(r.querySelector('.qi-p')?.value)||0;
    items.push({name,spec:r.querySelector('.qi-s')?.value||'',qty,unitPrice,amount:qty*unitPrice});
  });
  if(!items.length){alert('견적 항목을 입력해 주세요.');return;}
  const supplyAmt=items.reduce((s,i)=>s+i.amount,0);
  const vatAmt=Math.round(supplyAmt*0.1);
  const seq=Store.data.quotes.length+1;
  Store.data.quotes.push({id:uid(),quoteNo:`Q-2026-${String(seq).padStart(3,'0')}`,orderId,items,supplyAmt,vatAmt,totalAmt:supplyAmt+vatAmt,validUntil:document.getElementById('qValid')?.value,note:document.getElementById('qNote')?.value,status:'sent',createdBy:CU.id,createdAt:today()});
  const o=Store.data.orders.find(x=>x.id===orderId);
  if(o){o.status='quoted';o.staffId=CU.id;}
  Store.save(); go('order-detail',{id:orderId});
}

