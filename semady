};

// ═══════════════════════════════════════════════════════
//  라우터
// ═══════════════════════════════════════════════════════
let CU=null, PAGE='login', PARAMS={};
function go(page,params={}){PAGE=page;PARAMS=params;render();}
function logout(){CU=null;go('login');}

// ═══════════════════════════════════════════════════════
//  메인 렌더
// ═══════════════════════════════════════════════════════
function render(){
  const app=document.getElementById('app');
  if(!CU){app.innerHTML=loginHTML();return;}
  const isStaff=CU.role==='admin'||CU.role==='staff';
  let body='';
  switch(PAGE){
    case 'dashboard': body=isStaff?adminDash():clientDash(); break;
    case 'orders':    body=isStaff?adminOrders():clientOrders(); break;
    case 'order-new': body=newOrderHTML(); break;
    case 'order-detail': body=isStaff?adminDetail(PARAMS.id):clientDetail(PARAMS.id); break;
    case 'quote-builder': body=quoteBuilder(PARAMS.orderId); break;
    case 'settings':  body=settingsHTML(); break;
    default: body=isStaff?adminDash():clientDash();
  }
  app.innerHTML=`<div class="min-h-screen bg-slate-50 flex flex-col">${navHTML()}<main class="flex-1 max-w-6xl mx-auto w-full px-4 py-6"><div class="fade-in">${body}</div></main></div>`;
}

// ═══════════════════════════════════════════════════════
//  네비
// ═══════════════════════════════════════════════════════
function navHTML(){
  const isStaff=CU.role==='admin'||CU.role==='staff';
  const items=isStaff
    ?[['dashboard','대시보드'],['orders','주문관리'],['settings','설정']]
    :[['dashboard','대시보드'],['orders','내 주문'],['order-new','+ 새 주문']];
  const roleLabel=CU.role==='admin'?'관리자':CU.role==='staff'?'담당자':'고객';
  return `
  <nav class="bg-[#1E3A8A] text-white shadow-lg no-print">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-14">
      <div class="flex items-center gap-5">
        <button onclick="go('dashboard')" class="font-bold text-lg tracking-tight flex items-center gap-2">
          <span class="text-xl">📋</span><span class="hidden sm:block">주문·납품 관리</span>
        </button>
        <div class="hidden sm:flex items-center gap-0.5">
          ${items.map(([p,l])=>`<button onclick="go('${p}')" class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ${PAGE===p?'bg-blue-700':'hover:bg-blue-800'}">${l}</button>`).join('')}
        </div>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-sm text-blue-200 hidden sm:block">${CU.org} <strong>${CU.name}</strong> <span class="text-xs bg-blue-700 rounded-md px-1.5 py-0.5 ml-1">${roleLabel}</span></span>
        <button onclick="logout()" class="text-xs text-blue-300 hover:text-white border border-blue-600 hover:border-blue-400 px-3 py-1.5 rounded-lg transition-colors">로그아웃</button>
      </div>
    </div>
  </nav>`;
}

// ═══════════════════════════════════════════════════════
//  로그인
// ═══════════════════════════════════════════════════════
function loginHTML(){
  return `
  <div class="min-h-screen bg-gradient-to-br from-[#1E3A8A] to-[#2563EB] flex items-center justify-center p-4">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-white bg-opacity-20 rounded-2xl mb-4 text-3xl">📋</div>
        <h1 class="text-2xl font-bold text-white">주문·납품 관리</h1>
        <p class="text-blue-200 text-sm mt-1">관공서 전용 B2G 주문 시스템</p>
      </div>
      <div class="bg-white rounded-2xl shadow-2xl p-7">
        <div class="mb-4">
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">이메일</label>
          <input id="lEmail" type="email" placeholder="이메일 입력" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
        </div>
        <div class="mb-5">
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">비밀번호</label>
          <input id="lPw" type="password" placeholder="비밀번호 입력" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" onkeydown="if(event.key==='Enter')doLogin()">
        </div>
        <button onclick="doLogin()" class="w-full bg-[#1E3A8A] hover:bg-blue-900 text-white font-bold py-3 rounded-xl transition-colors text-sm shadow-lg shadow-blue-900/30">로그인</button>
        <div id="lErr" class="hidden text-red-500 text-xs text-center mt-2.5 bg-red-50 rounded-lg py-2">이메일 또는 비밀번호를 확인해 주세요.</div>
        <div class="mt-6 pt-5 border-t border-slate-100">
          <p class="text-xs text-slate-400 text-center mb-3 font-medium">― 데모 계정 ―</p>
          <div class="grid grid-cols-3 gap-2">
            ${[['🔧 관리자','admin@test.com'],['👤 담당자','staff@test.com'],['🏛 고객','client@test.com']].map(([l,e])=>`
              <button onclick="demoLogin('${e}')" class="text-xs border border-slate-200 rounded-xl py-2.5 hover:bg-blue-50 hover:border-blue-300 transition-all text-slate-600 font-medium">${l}</button>
            `).join('')}
          </div>
        </div>
      </div>
    </div>
  </div>`;
}
function doLogin(){
  const e=document.getElementById('lEmail').value.trim();
  const p=document.getElementById('lPw').value;
  const u=Store.data.users.find(x=>x.email===e&&x.pw===p&&x.isActive);
  if(u){CU=u;go('dashboard');}
  else document.getElementById('lErr').classList.remove('hidden');
}
function demoLogin(email){
  const u=Store.data.users.find(x=>x.email===email);
  if(u){CU=u;go('dashboard');}
}

// ═══════════════════════════════════════════════════════
//  유틸 컴포넌트
// ═══════════════════════════════════════════════════════
function badge(status){
  return `<span class="text-xs px-2.5 py-1 rounded-full font-semibold status-${status}">${STATUS_LABELS[status]||status}</span>`;
}
function card(content,extra=''){
  return `<div class="bg-white rounded-xl border border-slate-200 shadow-sm ${extra}">${content}</div>`;
}
function statCard(label,val,icon,clr='blue'){
  const bg={blue:'bg-blue-50 text-blue-600',amber:'bg-amber-50 text-amber-600',green:'bg-green-50 text-green-600',slate:'bg-slate-100 text-slate-500'};
  return `<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-center justify-between mb-3"><p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">${label}</p>
    <div class="w-9 h-9 rounded-xl ${bg[clr]} flex items-center justify-center text-base">${icon}</div></div>
    <p class="text-3xl font-bold text-slate-800">${val}</p></div>`;
}
function infoRow(l,v){
  return `<div class="flex gap-2 py-1"><dt class="text-slate-400 text-xs font-semibold uppercase tracking-wide w-20 shrink-0 pt-0.5">${l}</dt><dd class="text-slate-800 text-sm font-medium">${v||'—'}</dd></div>`;
}

// ═══════════════════════════════════════════════════════
//  클라이언트 대시보드
// ═══════════════════════════════════════════════════════
function clientDash(){
  const ords=Store.data.orders.filter(o=>o.clientId===CU.id);
  const recent=[...ords].reverse().slice(0,4);
  return `
  <div>
    <div class="flex items-center justify-between mb-6">
      <div><h2 class="text-xl font-bold text-slate-800">안녕하세요, ${CU.name}님 👋</h2>
      <p class="text-sm text-slate-500 mt-0.5">${CU.org} ${CU.dept}</p></div>
      <button onclick="go('order-new')" class="bg-[#1E3A8A] hover:bg-blue-900 text-white font-semibold px-5 py-2.5 rounded-xl text-sm shadow transition-colors flex items-center gap-1.5">
        <span class="text-base">+</span> 새 주문
      </button>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
      ${statCard('전체',ords.length,'📦','slate')}
      ${statCard('접수대기',ords.filter(o=>o.status==='submitted').length,'⏳','amber')}
      ${statCard('진행중',ords.filter(o=>!['completed','cancelled','submitted','draft'].includes(o.status)).length,'⚡','blue')}
      ${statCard('완료',ords.filter(o=>o.status==='completed').length,'✅','green')}
    </div>
    ${card(`
      <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
        <h3 class="font-semibold text-slate-700">최근 주문</h3>
        <button onclick="go('orders')" class="text-xs text-blue-600 hover:underline font-medium">전체보기 →</button>
      </div>
      ${recent.length===0
        ?`<div class="py-14 text-center text-slate-400"><p class="text-2xl mb-2">📭</p><p class="text-sm">주문 내역이 없습니다.</p>
           <button onclick="go('order-new')" class="mt-3 text-sm text-blue-600 hover:underline font-semibold">첫 주문 신청하기</button></div>`
        :recent.map(o=>`
          <div class="px-5 py-3.5 flex items-center gap-3 hover:bg-slate-50 cursor-pointer border-b border-slate-100 last:border-0" onclick="go('order-detail',{id:'${o.id}'})">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-slate-800 truncate">${o.title}</p>
              <p class="text-xs text-slate-400 mt-0.5">${o.orderNo} · ${ORDER_TYPES[o.type]} · ${fmt(o.createdAt)}</p>
            </div>
            <div class="flex items-center gap-2 shrink-0">${badge(o.status)}<span class="text-slate-300">›</span></div>
          </div>`).join('')}
    `)}
  </div>`;
}

// ═══════════════════════════════════════════════════════
//  관리자 대시보드
// ═══════════════════════════════════════════════════════
function adminDash(){
  const ords=Store.data.orders;
  const waiting=ords.filter(o=>o.status==='submitted');
  return `
  <div>
    <h2 class="text-xl font-bold text-slate-800 mb-6">관리자 대시보드</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
      ${statCard('전체 주문',ords.length,'📦','slate')}
      ${statCard('접수대기',waiting.length,'⏳','amber')}
      ${statCard('진행중',ords.filter(o=>!['completed','cancelled','submitted','draft'].includes(o.status)).length,'⚡','blue')}
      ${statCard('완료',ords.filter(o=>o.status==='completed').length,'✅','green')}
    </div>
    ${card(`
      <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
        <h3 class="font-semibold text-slate-700">⚠️ 처리 필요 주문 <span class="ml-1.5 text-xs bg-red-100 text-red-600 rounded-full px-2 py-0.5 font-bold">${waiting.length}</span></h3>
        <button onclick="go('orders')" class="text-xs text-blue-600 hover:underline font-medium">전체보기 →</button>
      </div>
      ${waiting.length===0
        ?`<div class="py-12 text-center text-slate-400 text-sm">✅ 처리 대기 주문이 없습니다.</div>`
        :waiting.map(o=>{
          const cl=Store.data.users.find(u=>u.id===o.clientId);
          return `<div class="px-5 py-4 flex items-center gap-4 hover:bg-amber-50 cursor-pointer border-b border-slate-100 last:border-0" onclick="go('order-detail',{id:'${o.id}'})">
            <div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center text-amber-600 text-lg shrink-0">⏳</div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-slate-800 truncate">${o.title}</p>
              <p class="text-xs text-slate-400 mt-0.5">${cl?.org} ${cl?.dept} · ${ORDER_TYPES[o.type]} · ${fmt(o.createdAt)}</p>
            </div>
            <button class="text-xs bg-[#1E3A8A] text-white px-3 py-2 rounded-lg hover:bg-blue-900 font-semibold whitespace-nowrap">처리 →</button>
          </div>`;
        }).join('')}
    `)}
  </div>`;
}

// ═══════════════════════════════════════════════════════
//  주문 목록 (공통)
// ═══════════════════════════════════════════════════════
function clientOrders(){
  return orderListHTML(Store.data.orders.filter(o=>o.clientId===CU.id).reverse(), false);
}
function adminOrders(){
  return orderListHTML([...Store.data.orders].reverse(), true);
}
function orderListHTML(orders, isAdmin){
  return `
  <div>
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-xl font-bold text-slate-800">${isAdmin?'전체 주문 관리':'내 주문 목록'}</h2>
      ${!isAdmin?`<button onclick="go('order-new')" class="bg-[#1E3A8A] text-white text-sm font-semibold px-4 py-2.5 rounded-xl hover:bg-blue-900 transition-colors">+ 새 주문</button>`:''}
    </div>
    ${card(`
      <div class="overflow-x-auto">
        ${orders.length===0?`<div class="py-16 text-center text-slate-400"><p class="text-3xl mb-2">📭</p><p>주문이 없습니다.</p></div>`:`
        <table class="w-full text-sm">
          <thead class="bg-slate-50 border-b border-slate-200">
            <tr>
              <th class="text-left px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">주문번호</th>
              ${isAdmin?'<th class="text-left px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">기관</th>':''}
              <th class="text-left px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">제목</th>
